{
  "name": "shopgenie",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run download:models && next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "lint": "eslint",
    "test:ranking": "tsx app/lib/ranking/test-ranking.ts",
    "test:constraints": "tsx app/lib/ranking/test-constraints.ts",
    "test:reviews": "tsx app/lib/ranking/test-reviews.ts",
    "dev:ranking": "tsx --watch app/lib/ranking/test-ranking.ts",
    "download:models": "tsx scripts/download-constraint-models.ts && tsx scripts/download-review-models.ts"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "compromise": "^14.15.0",
    "fastest-levenshtein": "^1.0.16",
    "franc-min": "^6.2.0",
    "lucide-react": "^0.548.0",
    "next": "^16.1.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "sentiment": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sentiment": "^5.0.4",
    "baseline-browser-mapping": "^2.9.17",
    "eslint": "^9",
    "eslint-config-next": "16.0.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
